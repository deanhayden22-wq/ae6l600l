# Default: auto-detect text, store with LF, check out with LF.
# This prevents Windows editors from re-introducing CRLF and creating
# spurious "every file modified" noise in git status.
* text=auto eol=lf

# Explicit binaries (do not normalize line endings)
*.bin     binary
*.hex     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.pdf     binary
*.zip     binary
*.exe     binary
*.pyc     binary
*.bytes   binary
*.ods     binary
*.xlsx    binary
*.xls     binary
