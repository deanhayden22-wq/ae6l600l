		<table name="Engine Speed (RPM)" address="db260" type="Y Axis" elements="10" scaling="MerpModRPM"/>
	</table>

	<table name="MerpMod Atmospheric Compensation" category="MerpMod Speed Density" address="db2cc" type="3D" level="3" scaling="MerpModAtmComp">
