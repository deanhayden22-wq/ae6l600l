<rom>
	<romid>
		<xmlid>AE5L600L_MerpMod</xmlid>
		<internalidaddress>2004</internalidaddress>
		<internalidstring>AE5L600L</internalidstring>
		<ecuid>8A12587007</ecuid>
		<make>Subaru</make>
		<market>USDM</market>
		<model>Impreza</model>
		<submodel>WRX</submodel>
		<transmission>MT</transmission>
		<year>13</year>
		<flashmethod>subarucan</flashmethod>
		<memmodel>SH7058</memmodel>
		<checksummodule>subarudbw</checksummodule>
	</romid>

	<include>AE5L600L</include>

	<!-- ================================================================ -->
	<!-- MerpMod Scalings                                                 -->
	<!-- ================================================================ -->

	<scaling name="MerpModVE" units="VE (ratio)" toexpr="x*0.0000457763672" frexpr="x/0.0000457763672" format="%.4f" min="0" max="1.5" inc="0.001" storagetype="uint16" endian="big"/>
	<scaling name="MerpModSDBlend" units="Blend (0=MAF,1=SD)" toexpr="x*0.003921568627451" frexpr="x/0.003921568627451" format="%.3f" min="0" max="1" inc="0.004" storagetype="uint8" endian="big"/>
	<scaling name="MerpModAtmComp" units="Multiplier" toexpr="x*0.000061037" frexpr="x/0.000061037" format="%.4f" min="0" max="2" inc="0.001" storagetype="uint16" endian="big"/>
	<scaling name="MerpModFloat" units="units" toexpr="x" frexpr="x" format="%.4f" min="-10000" max="100000" inc="0.01" storagetype="float" endian="big"/>
	<scaling name="MerpModRPM" units="RPM" toexpr="x" frexpr="x" format="%.0f" min="0" max="12000" inc="50" storagetype="float" endian="big"/>
	<scaling name="MerpModSpeed" units="km/h" toexpr="x" frexpr="x" format="%.1f" min="0" max="300" inc="1" storagetype="float" endian="big"/>
	<scaling name="MerpModSpeedMPH" units="mph" toexpr="x*0.621371" frexpr="x/0.621371" format="%.1f" min="0" max="200" inc="1" storagetype="float" endian="big"/>
	<scaling name="MerpModTemp" units="deg C" toexpr="x" frexpr="x" format="%.1f" min="-40" max="200" inc="1" storagetype="float" endian="big"/>
	<scaling name="MerpModTempF" units="deg F" toexpr="(x*1.8)+32" frexpr="(x-32)/1.8" format="%.1f" min="-40" max="400" inc="1" storagetype="float" endian="big"/>
	<scaling name="MerpModPressure" units="mmHg" toexpr="x" frexpr="x" format="%.0f" min="0" max="2500" inc="10" storagetype="float" endian="big"/>
	<scaling name="MerpModUint8" units="units" toexpr="x" frexpr="x" format="%.0f" min="0" max="255" inc="1" storagetype="uint8" endian="big"/>
	<scaling name="MerpModPercent" units="%" toexpr="x" frexpr="x" format="%.1f" min="0" max="100" inc="0.5" storagetype="float" endian="big"/>
	<scaling name="MerpModThreshold" units="units" toexpr="x" frexpr="x" format="%.2f" min="-100" max="100" inc="0.1" storagetype="float" endian="big"/>
	<scaling name="MerpModGearRatio" units="ratio" toexpr="x" frexpr="x" format="%.3f" min="0" max="10" inc="0.001" storagetype="float" endian="big"/>
	<scaling name="MerpModMafMode" storagetype="bloblist">
		<data name="MAF Sensor" value="00"/>
		<data name="Speed Density" value="01"/>
		<data name="SD Blending" value="02"/>
	</scaling>
	<scaling name="MerpModRevLimMode" storagetype="bloblist">
		<data name="Fuel Cut" value="01"/>
		<data name="Spark Cut" value="02"/>
	</scaling>
	<scaling name="MerpModFFSMode" storagetype="bloblist">
		<data name="Static" value="00"/>
		<data name="Automatic (Gear-Based)" value="01"/>
	</scaling>

	<!-- ================================================================ -->
	<!-- MerpMod Speed Density Tables                                     -->
	<!-- ================================================================ -->

	<table name="MerpMod VE Table 1" category="MerpMod Speed Density" address="db384" type="3D" level="4" scaling="MerpModVE">
		<table name="Manifold Pressure (mmHg)" address="db864" type="X Axis" elements="24" scaling="MerpModPressure"/>
		<table name="Engine Speed (RPM)" address="db804" type="Y Axis" elements="24" scaling="MerpModRPM"/>
	</table>

	<table name="MerpMod SD Blending Table" category="MerpMod Speed Density" address="db1fc" type="3D" level="3" scaling="MerpModSDBlend">
